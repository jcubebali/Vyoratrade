rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidTrade(data) {
      return data.symbol is string && data.symbol.size() <= 16
        && data.type is string && (data.type == 'BUY' || data.type == 'SELL')
        && data.price is number && data.price > 0
        && data.amount is number && data.amount > 0
        && data.keys().hasAll(['symbol', 'type', 'price', 'amount'])
        && data.keys().size() <= 7;
    }

    function isValidUserConfig(data) {
      return (!('binanceApiKey' in data) || data.binanceApiKey is string)
          && (!('binanceApiSecret' in data) || data.binanceApiSecret is string)
          && (!('telegramBotId' in data) || data.telegramBotId is string)
          && (!('telegramChatId' in data) || data.telegramChatId is string)
          && (!('webhookToken' in data) || data.webhookToken is string);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUserConfig(request.resource.data);
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUserConfig(request.resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['binanceApiKey', 'binanceApiSecret', 'telegramBotId', 'telegramChatId', 'webhookToken']);
    }

    match /trades/{tradeId} {
      allow read: if isSignedIn();
      allow create: if isValidId(tradeId) && isValidTrade(request.resource.data);
    }
  }
}
